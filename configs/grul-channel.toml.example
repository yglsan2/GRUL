# Configuration canaux GRUL — exemple
# Copier vers /etc/grul/channel.toml

[channel]
core_enabled = true
current_enabled = true
edge_enabled = false

[sources]
uri = "https://repo.grul.org/debian"
core_suite = "grul-core"
current_suite = "grul-current"
edge_suite = "grul-edge"
components = "main"

[packages]
firefox-esr = "current"
linux-image-amd64 = "current"
docker.io = "edge"

[update]
snapshot_before_current = true
auto_security = true
